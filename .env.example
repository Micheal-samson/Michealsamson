# ── Server ──────────────────────────────────
PORT=3001

# Origin of your portfolio site (set to your actual domain in production)
ALLOWED_ORIGIN=*

# ── Groq AI (free) ──────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=

# ── Email (Gmail recommended) ────────────────
# Your Gmail address
EMAIL_USER=you@gmail.com

# Gmail App Password — NOT your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (You must have 2-Step Verification enabled first)
EMAIL_PASS=your_app_password_here

# Where contact form notifications get sent (usually same as EMAIL_USER)
EMAIL_TO=you@gmail.com

# ── Supabase ─────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
